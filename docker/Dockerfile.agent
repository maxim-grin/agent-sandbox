FROM python:3.11.9-slim

RUN apt-get update -qq \
    && apt-get install -y --no-install-recommends openssh-client \
    && rm -rf /var/lib/apt/lists/*

RUN pip install --no-cache-dir openhands-ai paramiko

RUN groupadd -g 1000 agentgroup && useradd -u 1000 -g agentgroup -m agentuser

RUN mkdir -p /app /sandbox/results \
    && chown -R agentuser:agentgroup /app /sandbox

WORKDIR /app

USER agentuser

CMD ["sleep", "infinity"]
