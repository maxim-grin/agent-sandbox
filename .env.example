# --- LLM Provider (required) ---
LLM_PROVIDER=groq
LLM_MODEL_ID=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1
LLM_API_KEY=

# --- Ollama (swap in to use local Ollama instead of cloud) ---
# Prerequisite: ollama pull qwen3:0.6b
# LLM_PROVIDER=ollama
# LLM_MODEL_ID=qwen3:0.6b
# LLM_BASE_URL=  # derived from OLLAMA_HOST automatically
# OLLAMA_HOST=http://host.docker.internal:11434  # default

# --- opencode server (optional overrides) ---
# OPENCODE_PORT=4096
# OPENCODE_HOST=127.0.0.1

# --- Timeouts ---
TIMEOUT_STAGE=600