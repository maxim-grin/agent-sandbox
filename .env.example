# --- Groq (cloud) ---
#LLM_MODEL=groq/llama-3.3-70b-versatile
#LLM_PROVIDER=groq
#GROQ_API_KEY=
#LLM_BASE_URL=https://api.groq.com/openai/v1

# --- Ollama (local) ---
# Prerequisite: ollama pull gemma3:1b
LLM_MODEL=ollama/gemma3:1b
LLM_PROVIDER=ollama
LLM_MODEL_ID=gemma3:1b
LLM_BASE_URL=http://host.docker.internal:11434/v1
# Timeout setting per stage
TIMEOUT_STAGE=600